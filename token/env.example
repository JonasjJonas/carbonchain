# token/.env — variáveis de ambiente para deploy
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env para o git

# Chave privada da carteira de deploy
# ⚠️  Use uma carteira dedicada para deploy — nunca a carteira principal
PRIVATE_KEY=sua_chave_privada_aqui

# RPC endpoint da Sepolia (testnet)
# Opções gratuitas: Alchemy (alchemy.com) ou Infura (infura.io)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/sua_api_key

# Etherscan API Key (opcional — para verificar contratos publicamente)
ETHERSCAN_API_KEY=sua_api_key_etherscan

# Endereço do CartesiDApp deployado (preencher após deploy do Cartesi)
CARTESI_ROLLUP_ADDR=0x0000000000000000000000000000000000000000

# Endereço do multisig da CarbonChain (tesouraria que recebe os tokens)
TESOURARIA_ADDR=0x0000000000000000000000000000000000000000
